# ==========================================
# Environment / Secrets (CRITICAL)
# ==========================================
# Block all local environment files, but allow the template/example file
.env
package.json
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key

# Un-ignore the example file so team members know what variables to set
!.env.example

# ==========================================
# Next.js and Build Outputs
# ==========================================
.next/
out/
build/
dist/

# ==========================================
# Node.js & Dependency Managers
# ==========================================
node_modules/
/jspm_packages
.npm
.eslintcache
.stylelintcache


# Yarn / pnpm specific (uncomment if you use them)
# .pnpm-debug.log*
# .yarn/install-state.gz

# ==========================================
# TypeScript & Testing
# ==========================================
# Next.js manages tsconfig.tsbuildinfo automatically
*.tsbuildinfo
coverage/
.nyc_output/

# ==========================================
# Logs and Diagnostics
# ==========================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================
# OS & IDEs (Mac, Windows, VS Code)
# ==========================================
.DS_Store
Thumbs.db
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/